# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/

# Virtual environments
.venv/
.venv-1/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
*.xml

# Type checking
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Secrets / env
.env
.env.*
*.pem
*.key

# Cluster credentials — never commit kubeconfig
.kube/

# Model weights and large artifacts
*.safetensors
*.bin
*.pt
*.ckpt
*.gguf
*.weights

# Benchmark outputs (generated — phase4 only; phase1/2/3 results are verified live data)
phases/phase4-benchmarks/results/
outputs/
sessions/

# Terraform — never commit state, plans, or actual variable values
# NOTE: .terraform.lock.hcl is intentionally NOT ignored — it pins the
# provider version (Linode 2.41.2) and must be committed for reproducibility.
infrastructure/terraform/.terraform/
infrastructure/terraform/terraform.tfstate
infrastructure/terraform/terraform.tfstate.backup
infrastructure/terraform/*.tfplan
infrastructure/terraform/*.tfvars
