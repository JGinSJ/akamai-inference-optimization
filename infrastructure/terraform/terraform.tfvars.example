# terraform.tfvars.example
#
# Copy this file to terraform.tfvars and adjust values as needed.
# terraform.tfvars is gitignored — never commit actual variable values.
# Never put a LINODE_TOKEN value in any .tf or .tfvars file.
# Set the token as an environment variable:
#   export LINODE_TOKEN="<your-personal-access-token>"
#
# To apply:
#   terraform init
#   terraform plan
#   terraform apply

region        = "us-ord"        # Chicago, IL — confirmed 2026-04-11
k8s_version   = "1.35"          # latest available as of 2026-04-11
cluster_label = "akamai-inference-opt"
cluster_tags  = ["inference-optimization"]

# CPU node pool (Valkey + supporting services)
# g6-dedicated-4: 4 vCPU, 8 GB RAM, dedicated cores — $0.108/hr (~$78/mo)
cpu_node_type  = "g6-dedicated-4"
cpu_node_count = 1

# RTX 4000 Ada GPU node pool (Phase 2–3 workloads, Phase 4 single-GPU bench)
# g2-gpu-rtx4000a1-l: 1x Ada, 16 vCPU, 64 GB RAM — $0.96/hr (~$691/mo)
ada_node_type  = "g2-gpu-rtx4000a1-l"
ada_node_count = 1

# RTX PRO 6000 Blackwell GPU node pool (Phase 4 benchmarks)
# NOT YET AVAILABLE — plan slug is PLACEHOLDER.
# Uncomment and set blackwell_node_type once the plan is confirmed in the API.
# See node-pool-blackwell.tf for activation steps.
#
# blackwell_node_type  = "PLACEHOLDER"   # replace with confirmed plan slug
# blackwell_node_count = 1
